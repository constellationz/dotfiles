#!/usr/bin/bash
# Installs everything in order.

SCRIPT_DIR=$(dirname "$0")

# First, install paru and command line programs.
$SCRIPT_DIR/install-paru
$SCRIPT_DIR/install-cli-programs

# Then install mesa and everything involving my desktop environment.
$SCRIPT_DIR/install-mesa
$SCRIPT_DIR/install-awesome
$SCRIPT_DIR/install-gtk-themes
$SCRIPT_DIR/install-qt-themes

# Finally, install user programs.
$SCRIPT_DIR/install-user-programs
